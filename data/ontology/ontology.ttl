@prefix ont: <http://example.org/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ont:Configuration a owl:Class ;
    rdfs:label "Configuration" ;
    rdfs:comment "Proposed from: ZDU_prereqs.txt; ZDU_prereqs.txt; ZDU_prereqs.txt" ;
    rdfs:subClassOf ont:Technology ;
    owl:equivalentClass <http://www.wikidata.org/entity/Q1866689>,
        <http://www.wikidata.org/entity/Q5160117> .

ont:Date a owl:Class ;
    rdfs:label "Date" ;
    rdfs:comment "A date or time period" .

ont:Document a owl:Class ;
    rdfs:label "Document" ;
    rdfs:comment "Proposed from: ZDU_prereqs.txt; ZDU_prereqs.txt; ZDU_prereqs.txt" ;
    rdfs:subClassOf ont:Other .

ont:Error a owl:Class ;
    rdfs:label "Error" ;
    rdfs:comment "Proposed from: ZDU_prereqs.txt" ;
    rdfs:subClassOf ont:flaw ;
    owl:equivalentClass <http://www.wikidata.org/entity/Q29485> .

ont:Event a owl:Class ;
    rdfs:label "Event" ;
    rdfs:comment "An event or occurrence" .

ont:Location a owl:Class ;
    rdfs:label "Location" ;
    rdfs:comment "A geographical place or location" .

ont:Mcp_Server a owl:Class ;
    rdfs:label "Mcp Server" ;
    rdfs:comment "Proposed from: MCP.txt (triple: Git MCP Server isA MCP Server); MCP.txt (triple: Filesystem MCP Server isA MCP Server)" ;
    rdfs:subClassOf ont:Technology .

ont:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "A company, institution, or group" .

ont:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human being or individual" .

ont:Product a owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "A product or service" .

ont:Railway a owl:Class ;
    rdfs:label "Railway" ;
    rdfs:comment "Proposed from: industrial_revolution.txt (triple: Liverpool-Manchester Railway is_a railway); industrial_revolution.txt (triple: Transcontinental Railroad is_a railway)" ;
    rdfs:subClassOf ont:rail_network ;
    owl:equivalentClass <http://www.wikidata.org/entity/Q728937> .

ont:Version a owl:Class ;
    rdfs:label "Version" ;
    rdfs:comment "Proposed from: ZDU_prereqs.txt; ZDU_prereqs.txt; ZDU_prereqs.txt; ZDU_prereqs.txt; ZDU_prereqs.txt" ;
    rdfs:subClassOf ont:Technology .

ont:Concept a owl:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "An abstract concept or idea" .

ont:Other a owl:Class ;
    rdfs:label "Other" ;
    rdfs:comment "Other type of entity" .

ont:flaw a owl:Class ;
    rdfs:label "flaw" ;
    rdfs:comment "Added via Wikidata P279 lookup (wd:Q1747121)" ;
    rdfs:subClassOf ont:undesirable_characteristic ;
    owl:equivalentClass <http://www.wikidata.org/entity/Q1747121> .

ont:rail_network a owl:Class ;
    rdfs:label "rail network" ;
    rdfs:comment "Added via Wikidata P279 lookup (wd:Q57498564)" ;
    rdfs:subClassOf ont:transport_network ;
    owl:equivalentClass <http://www.wikidata.org/entity/Q2678338>,
        <http://www.wikidata.org/entity/Q57498564> .

ont:transport_infrastructure a owl:Class ;
    rdfs:label "transport infrastructure" ;
    rdfs:comment "Added via Wikidata P279 lookup (wd:Q376799)" ;
    rdfs:subClassOf ont:Technology ;
    owl:equivalentClass <http://www.wikidata.org/entity/Q376799> .

ont:transport_network a owl:Class ;
    rdfs:label "transport network" ;
    rdfs:comment "Added via Wikidata P279 lookup (wd:Q924286)" ;
    rdfs:subClassOf ont:transport_infrastructure ;
    owl:equivalentClass <http://www.wikidata.org/entity/Q924286> .

ont:undesirable_characteristic a owl:Class ;
    rdfs:label "undesirable characteristic" ;
    rdfs:comment "Added via Wikidata P279 lookup (wd:Q29479670)" ;
    rdfs:subClassOf ont:Concept ;
    owl:equivalentClass <http://www.wikidata.org/entity/Q29479670> .

<http://www.wikidata.org/entity/Q2678338> a owl:Class .

<http://www.wikidata.org/entity/Q376799> a owl:Class .

<http://www.wikidata.org/entity/Q57498564> a owl:Class .

<http://www.wikidata.org/entity/Q728937> a owl:Class .

<http://www.wikidata.org/entity/Q924286> a owl:Class .

ont:Technology a owl:Class ;
    rdfs:label "Technology" ;
    rdfs:comment "A technology, tool, or platform" .

[] a owl:Ontology .

